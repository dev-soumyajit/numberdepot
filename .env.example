# ============================================
# NumberDepot — Environment Variables
# ============================================
# Copy to apps/web/.env.local for local dev
# Copy to .env for Docker deployment

# ── MongoDB ──
# Local dev (Atlas):
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/numberdepot
# Docker deployment (auto-configured via MONGO_USER/MONGO_PASS):
MONGO_USER=admin
MONGO_PASS=your_strong_password_here

# ── Email (Resend) ──
RESEND_API_KEY=re_your_resend_api_key

# ── JWT Authentication ──
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── App URL ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── NumberBarn API ──
NUMBERBARN_API_TOKEN=your_numberbarn_api_token
NUMBERBARN_MARKUP=15

# ── Docker ──
PORT=3000
