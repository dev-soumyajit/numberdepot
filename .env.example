# ============================================
# NumberDepot — Environment Variables
# ============================================
# Copy to apps/web/.env.local and fill in values

# ── MongoDB ──
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/numberdepot

# ── Email (Resend) ──
RESEND_API_KEY=re_your_resend_api_key

# ── JWT Authentication ──
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── App URL ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── NumberBarn API ──
NUMBERBARN_API_TOKEN=your_numberbarn_api_token
NUMBERBARN_MARKUP=15
